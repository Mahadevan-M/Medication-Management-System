        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Chrome against localhost",
            "url": "git+https://github.com/mdbootstrap/bootstrap-login-form.git",
            "webRoot": "${workspaceFolder}"
        }
    ]
